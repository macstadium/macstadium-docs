%%  On-Premises / Self-Hosted Architecture
%%  Source of truth for images/onprem-arch.svg
%%  flowchart LR — left-to-right architecture view

flowchart LR
    admin(["IT Admin"])
    subgraph users["End users (any device, anywhere)"]
        laptop["Laptop / Desktop"]
        tablet["Tablet"]
        thin["Thin client (CWA)"]
    end
    subgraph broker["VDI broker / gateway\ne.g., Citrix DaaS / HP Anyware"]
        dc["Delivery Controller\n(brokers sessions, SSO/MFA)"]
    end
    identity["Identity\nActive Directory /\nEntra ID / Okta"]

    subgraph customer_dc["Customer Data Center / On-Prem"]
        subgraph cp["MacStadium VDI control plane\n(Customer-deployed & managed)"]
            orch["Orka Engine orchestration"]
            prov["Ansible (CLI) / Management UI (web)"]
            lifecycle["VM lifecycle · images · API"]
        end
        subgraph shared["Shared services (customer-provided or MSP-managed)"]
            registry["Golden image registry (OCI)"]
            mdm["MDM (Jamf / Kandji)"]
            storage["Backup / network storage"]
            mon["Monitoring & logging"]
            dns["DNS / DHCP / NTP"]
        end
        subgraph hosts["Apple silicon hosts (Mac mini / Mac Studio)"]
            subgraph h1["Host 1"]
                vm1a["macOS VM — VDI agent + user apps (user A)"]
                vm1b["macOS VM — VDI agent + user apps (user B)"]
            end
            subgraph h2["Host 2"]
                vm2a["macOS VM — VDI agent + user apps (user C)"]
                vm2b["macOS VM — VDI agent + user apps (user D)"]
            end
            subgraph hN["Host N (scale out)"]
                vmN["…"]
            end
        end
        net["Management VLAN · bridged tenant network · static IPs / DHCP reservations\n(customer-owned networking)"]
    end

    admin --> cp
    laptop -->|"remoting protocol"| dc
    dc -->|"remoting protocol"| laptop
    broker --> identity
    dc --> hosts
    cp -->|"manages"| hosts
